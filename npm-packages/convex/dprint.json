{
  "excludes": [
    "temp",
    ".git/",
    "dist/",
    "api-extractor-configs/reports",
    "api-extractor-configs/temp",
    "tmpDist*",
    "cli-management-openapi.json",
    "function-logs-openapi.json",
    "src/cli/generatedApi.ts",
    "src/cli/lib/generatedFunctionLogsApi.ts",
    "src/vendor",
    "CHANGELOG.md"
  ],
  "prettier": {
    "proseWrap": "always",
    "trailingComma": "all"
  },
  "plugins": [
    "https://plugins.dprint.dev/prettier-0.72.0.json@6e7af2cb2182a5a11358d3adde9ae0ef3b94b7d2e5dcfdd252e3f7c3916541fe"
  ]
}
