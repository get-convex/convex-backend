    "@xmldom/xmldom@0.8.12": "^0.8.13",
    "ajv@>=8.0.0 <8.18.0": "^8.18.0",
    "ajv@>=6.0.0 <6.14.0": "^6.14.0",
    "axios@>=1.0.0 <1.13.5": "^1.13.5",
    "basic-ftp@>=5.0.0 <5.2.0": "^5.2.0",
    "body-parser@>=2.2.0 <2.2.1": "^2.2.2",
    "brace-expansion@1.1.12": "1.1.13",
    "brace-expansion@2.0.2": "2.0.3",
    "brace-expansion@>=5.0.0 <5.0.5": "^5.0.5",
    "cookie@<0.7.0": "^0.7.2",
    "diff@>=8.0.0 <8.0.3": "^8.0.3",
    "diff@>=4.0.0 <4.0.4": "^4.0.4",
    "dompurify@>=3.0.0 <=3.3.3": "^3.4.0",
    "effect@>=3.0.0 <3.20.0": "^3.20.0",
    "esbuild@<=0.24.2": "0.25.0",
    "follow-redirects@1.15.11": "1.16.0",
    "glob@>=10.2.0 <10.5.0": "^10.5.0",
    "express-rate-limit@>=8.0.0 <8.2.2": "^8.2.2",
    "fast-xml-parser@>=4.3.6 <=5.5.6": "^5.5.7",
    "flatted@>=3.0.0 <3.4.2": "^3.4.2",
    "form-data@>=2.5.0 <2.5.5": "2.5.5",
    "form-data@>=4.0.0 <4.0.4": "4.0.4",
    "glob@>=11.0.0 <11.1.0": "^11.1.0",
    "h3@<=1.15.4": "^1.15.5",
    "h3@>=2.0.0-0 <2.0.1-rc.18": "^2.0.1-rc.18",
    "h3@2.0.1-rc.14": "^2.0.1-rc.18",
    "@tanstack/start-server-core>h3-v2": "npm:h3@^2.0.1-rc.18",
    "handlebars@>=4.0.0 <4.7.9": "^4.7.9",
    "http-proxy-middleware@2.0.8": "^2.0.9",
    "http-proxy-middleware@2.0.9": "^2.0.9",
    "http-proxy@1.11.1": "^1.18.1",
    "immutable@>=5.0.0 <5.1.5": "^5.1.5",
    "js-yaml@>=3.0.0 <3.14.2": "^3.14.2",
    "js-yaml@>=4.0.0 <4.1.1": "^4.1.1",
    "jws@4.0.0": "^4.0.1",
