    "seroval-plugins@<=1.4.0": "^1.4.1",
    "sha.js@2.4.11": "^2.4.12",
    "smol-toml@1.5.2": "1.6.1",
    "srvx@>=0.8.0 <0.11.13": "^0.11.13",
    "svgo@>=3.0.0 <3.3.3": "^3.3.3",
